{
  "name": "@hanfani/core",
  "version": "0.1.2",
  "description": "Headless engine and types for the Hanfani agent framework.",
  "license": "MIT",
  "author": "Aziz Mashkour",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/fruitizz/hanfani-core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fruitizz/hanfani-core.git"
  },
  "bugs": {
    "url": "https://github.com/fruitizz/hanfani-core/issues"
  },
  "keywords": [
    "hanfani",
    "agent",
    "workflow",
    "ai",
    "human-in-the-loop"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepublishOnly": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.55",
    "zod": "^3.25.76"
  },
  "engines": {
    "node": ">=20.19"
  },
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "typescript": "^7.0.2",
    "vitest": "^2.1.0"
  }
}
