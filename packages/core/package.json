{
  "name": "@hanfani/core",
  "version": "0.1.1",
  "description": "Headless engine and types for the Hanfani agent framework.",
  "license": "MIT",
  "author": "Aziz Mashkour",
  "type": "module",
  "sideEffects": false,
  "files": ["dist", "src"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/fruitizz/hanfani-framework/tree/HEAD/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fruitizz/hanfani-framework.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/fruitizz/hanfani-framework/issues"
  },
  "keywords": ["hanfani", "agent", "workflow", "ai", "human-in-the-loop"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepublishOnly": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.55",
    "zod": "^3.25.76"
